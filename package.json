{
  "name": "record-workspace",
  "version": "0.4.1",
  "private": true,
  "description": "Homebrew-distributed native macOS capture and local transcription CLI.",
  "type": "module",
  "workspaces": [
    "packages/capture",
    "packages/transcribe",
    "packages/live"
  ],
  "scripts": {
    "setup:capture": "npm --workspace capture run setup",
    "setup:transcribe": "npm --workspace transcribe run setup",
    "setup:live": "npm --workspace live run build && packages/live/dist/live setup",
    "setup": "npm run install:local && $HOME/.local/bin/record-dev setup",
    "build:bundle": "npm --workspaces run build",
    "build:binary:macos-arm64": "./scripts/build-release-macos-arm64.sh",
    "build:release:macos-arm64": "./scripts/build-release-macos-arm64.sh",
    "doctor": "./scripts/doctor-all.sh",
    "install:local": "./scripts/install-record-local.sh",
    "plugin:smoke": "./plugins/record/scripts/smoke-test.sh",
    "test:record": "./scripts/test-record-cli.sh",
    "test": "npm --workspaces test && npm run test:record && npm run plugin:smoke && npm run version:check",
    "version:check": "node scripts/update-release-version.mjs --check",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.3"
  }
}
